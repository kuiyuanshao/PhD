from ctgan_me import CTGAN
from data_sampler import DataSampler
from data_transformer import DataTransformer
import pandas as pd
import numpy as np


data = pd.read_csv("data_mis.csv")
discrete_columns = ["Z"]
ctgan = CTGAN(epochs = 1000)
ctgan.fit(data, discrete_columns)
#ctgan._cluster_data.to_csv("data_mis_cluster.csv", sep = "\t")
imp = ctgan.impute()
imp


import plotly
import plotly.express as px
fig = px.scatter(pd.DataFrame(imp), x="X", y="Y", title='Epoch vs. Loss')
fig.show()


loss_values = ctgan.loss_values
loss_values_reformatted = pd.melt(
    loss_values,
    id_vars=['Epoch'],
    var_name='Loss Type'
)

fig = px.line(loss_values_reformatted, x="Epoch", y="value", color="Loss Type", title='Epoch vs. Loss')
fig.show()


from sklearn.linear_model import LinearRegression

x = imp[["X", "Z"]]
y = imp["Y"]

regressor = LinearRegression()
regressor.fit(x, y)
regressor.coef_




imp.to_csv("imputation.csv", sep = "\t")
