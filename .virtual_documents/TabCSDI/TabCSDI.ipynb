)

model = TabCSDI(config, "cpu").to("cpu")
current_time = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
foldername = "./save/data_fold" + str(5) + "_" + current_time + "/"

model.load_state_dict(torch.load("./save/data_fold5_20240327_233431" + "/model.pth"))
