knitr::opts_chunk$set(echo = TRUE)
library(mixgb)
simtwophasepaper <- function(SD = c(sqrt(3), sqrt(3))){
Nsim <- 3000
n  <- 10000
n2 <- 2000
######################################
beta <- c(1, 1, 1)
e_U <- SD
mx <- 0; sx <- 1; zrange <- 1; zprob <- .5
simZ   <- rbinom(n, zrange, zprob)
simX   <- (1-simZ)*rnorm(n, 0, 1) + simZ*rnorm(n, 0.5, 1)
epsilon <- rnorm(n, 0, 1)
simY    <- beta[1] + beta[2]*simX + beta[3]*simZ + epsilon
simX_tilde <- simX + rnorm(n, 0, e_U[1]*(simZ==0) + e_U[2]*(simZ==1))
data <- data.frame(X_tilde=simX_tilde, Y=simY, X=simX, Z=simZ)
return (data)
}
set.seed(666)
data <- simtwophasepaper()
id <- sample(1:10000, 8000)
data_mis <- data
data_mis$X[id] <- NA
data_mis
?mixgb
mixgb_data <- mixgb(data_mis, initial.num = "sample")
mixgb_data
lm(Y ~ X + Z, mixgb_data[[1]])
mixgb_data2 <- mixgb(data_mis)
lm(Y ~ X + Z, mixgb_data[[1]])
lm(Y ~ X + Z, mixgb_data2[[1]])
lm(Y ~ X + Z, mixgb_data[[1]])
lm(Y ~ X + Z, mixgb_data2[[1]])
lm(Y ~ X + Z, mixgb_data[[1]])
lm(Y ~ X + Z, mixgb_data2[[1]])
lm(Y ~ X + Z, mixgb_data[[1]])
lm(Y ~ X + Z, data)
data
knitr::opts_chunk$set(echo = TRUE)
observed <- read.csv("observed_2.csv", sep = "\t")
imputed <- read.csv("imputed_2.csv", sep = "\t")
observed
for (i in 2:5){
observed[observed[, i] == 0, i] <- imputed[observed[, i] == 0, i]
}
imputed <- observed
names(imputed) = c("index", "X_tilde", "Y", "X", "Z")
imputed <- imputed[, -1]
max_ <- lapply(miss, max, na.rm = T)
max_ <- (unlist(max_) + 1)
miss <- read.csv("miss.csv")
max_ <- lapply(miss, max, na.rm = T)
max_ <- (unlist(max_) + 1)
for (i in 1:4){
imputed[, i] <- imputed[, i] * max_[i] - 1
}
imputed$Z <- round(imputed$Z)
lm(Y ~ X + Z, imputed)
ggplot(imputed[is.na(miss$X), ]) + geom_point(aes(x = X, y = Y))
library(ggplot2)
ggplot(imputed[is.na(miss$X), ]) + geom_point(aes(x = X, y = Y))
